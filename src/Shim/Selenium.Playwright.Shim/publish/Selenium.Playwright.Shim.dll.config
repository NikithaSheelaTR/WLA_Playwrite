<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.LogDebug4NetConfigurationSectionHandler, log4net" />
  </configSections>
  <log4net>
    <appender name="RP" type="ReportPortal.Log4Net.ReportPortalAppender, ReportPortal.Log4Net">
      <layout type="log4net.Layout.SimpleLayout" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionpattern value="%message%newline" />
      </layout>
    </appender>
    <logger name="ReportPortal">
      <appender-ref ref="RP" />
    </logger>
    <appender name="consoleAppender" type="log4net.Appender.ConsoleAppender">
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%level: [%date] – message:%message %newline" />
      </layout>
      <filter type="log4net.Filter.LevelRangeFilter">
        <levelMin value="INFO" />
        <levelMax value="ERROR" />
      </filter>
      <filter type="log4net.Filter.DenyAllFilter" />
    </appender>
    <appender name="fileAppender" type="log4net.Appender.FileAppender">
      <file type="log4net.Util.PatternString" value="Log/%property{LogName}" />
      <appendToFile value="true" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%-5p%d{ yyyy-MM-dd HH:mm:ss} – message:%message %newline" />
      </layout>
    </appender>
    <logger name="ConsoleAndFile">
      <appender-ref ref="consoleAppender" />
      <appender-ref ref="fileAppender" />
    </logger>
    <logger name="Console">
      <appender-ref ref="consoleAppender" />
    </logger>
  </log4net>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="amqmdnet" publicKeyToken="dd3cb1c9aae9ec97" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-7.1.0.6" newVersion="7.1.0.6" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="amqmdxcs" publicKeyToken="7a58d55a51981a15" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-7.1.0.6" newVersion="7.1.0.6" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="amqmdnsp" publicKeyToken="4ec3909022c7abcc" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-7.1.0.6" newVersion="7.1.0.6" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="IBM.XMS" publicKeyToken="d2666ab12fca862b" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2.1.0.6" newVersion="2.1.0.6" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="amqmxmsstd" publicKeyToken="d2666ab12fca862b" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-9.2.4.0" newVersion="9.2.4.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="amqmdnetstd" publicKeyToken="23d6cb914eeaac0e" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-9.2.4.0" newVersion="9.2.4.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Text.Json" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.11" newVersion="6.0.0.11" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Text.Encodings.Web" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.1" newVersion="6.0.0.1" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.1" /></startup></configuration>
