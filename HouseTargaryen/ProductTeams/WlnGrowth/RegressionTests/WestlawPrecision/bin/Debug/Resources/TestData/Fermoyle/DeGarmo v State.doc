 665 S.W.2d 771, 781 (Tex.Cr.App.1983)
}}}
{\b0 \cf1 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
; 
}
{\field {\*\fldinst HYPERLINK "http://wwwtest.int.westlaw.com/Link/Document/FullText?findType=Y&serNum=1976138799&pubNum=713&originatingDoc=Ic2428eb5e7bc11d9b386b232635db992&refType=RP&fi=co_pp_sp_713_122&originationContext=document&vr=3.0&rs=cblt1.0&transitionType=DocumentItem&contextData=(sc.History*oc.DocAnalysisJudicial)#co_pp_sp_713_122" }{\fldrslt 
