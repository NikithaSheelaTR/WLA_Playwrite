 or 
}
{\field {\*\fldinst HYPERLINK "http://wwwtest.int.westlaw.com/Link/Document/FullText?findType=L&pubNum=1000228&cite=CAWIS602&originatingDoc=I465a5b3aeb7211dfaa23bccc834e9520&refType=LQ&originationContext=document&vr=3.0&rs=cblt1.0&transitionType=DocumentItem&contextData=(sc.History*oc.Search)" }{\fldrslt 
