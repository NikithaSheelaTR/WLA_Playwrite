{\super \b0 \cf28 \f2 \ul0 \strike0 \i0 \fs16 \sa0 \sb0 
2
}}}
\par 
}
}
}
{\b0 \cf1 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
\u160\'3f
\par 
}
