{
  // Maps AwardRange to NovusWebElementInfo
  "None": {
    "Text": "$0",
    "NovusInfo": "$0"
  },
  "From1To49000": {
    "Text": "$1 - $49,999",
    "NovusInfo": "$1-49,999"
  },
  "From50000To99999": {
    "Text": "$50,000 - $99,999",
    "NovusInfo": "$50,000-99,999"
  },
  "From100000To199999": {
    "Text": "$100,000 - $199,999",
    "NovusInfo": "$100,000-199,999"
  },
  "From200000To499999": {
    "Text": "$200,000 - $499,999",
    "NovusInfo": "$200,000-499,999"
  },
  "From500000To999999": {
    "Text": "$500,000 - $999,999",
    "NovusInfo": "$500,000-999,999"
  },
  "From1MTo2M": {
    "Text": "$1M - $1,999,999",
    "NovusInfo": "$1,000,000-1,999,999"
  },
  "From2MTo5M": {
    "Text": "$2M - $4,999,999",
    "NovusInfo": "$2,000,000-4,999,999"
  },
  "Over5M": {
    "Text": "$5M+",
    "NovusInfo": "$5,000,000-999,999,999"
  }
}