{
	//Map for FundsFilerSearchSubItem
	"HighlightedSeriesClass": {
		"LocatorMask":
			"(//a[contains(@href,'{0}')])[1]/span[contains(@class,'co_highlightLink')]"
	},
	"HighlightedSeriesFormerNames": {
		"LocatorMask":
			"(//a[contains(@class,'co_pickListTitle ng-binding')]/../..//a[contains(@href,'{0}')])[1]/../div/span[contains(@class,'co_highlightText')]"
	},
	"HighlightedSeriesLink": {
		"LocatorMask":
			"(//a[contains(@class,'co_pickListTitle ng-binding')]/../..//a/span[text()='{0}' and contains(@class,'co_highlightLink')])"
	},
	"HighlightedTicker": {
		"LocatorMask":
			"(//a[contains(@href,'{0}')]/..//span[contains(text(),'{1}') and contains(@class,'co_highlightText')])[1]"
	},
	"NotHighlightedSeriesClass": {
		"LocatorMask": "(//a[contains(@href,'{0}')])[1]"
	},
	"NotHighlightedSeriesLink": {
		"LocatorMask":
			"(//a[contains(@class,'co_pickListTitle ng-binding')]/../..//a[text()='{0}'])"
	},
	"NotHighlightedTicker": {
		"LocatorMask": "(//a[contains(@href,'{0}')]/..//span[contains(text(),'{1}')])[1]"
	},
	"SeriesFormerNames": {
		"LocatorMask": "(//a[contains(@class,'co_pickListTitle ng-binding')]/../..//a[contains(@href,'{0}')])[1]/../div[1]"
	}
